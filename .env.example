# Max upload size in MB
MAX_UPLOAD_MB=25

# Allowed audio file extensions (comma-separated)
ALLOWED_EXTENSIONS=webm,wav,m4a,mp3,ogg,flac

# Whisper model name: tiny, base, small, medium, large
WHISPER_MODEL=base

# Optional fixed language (e.g. en, es). Leave empty for auto-detection.
WHISPER_LANGUAGE=

# Timeout for transcription in seconds (0 = unlimited)
WHISPER_TIMEOUT_SEC=1800

# Optional override for estimated processing time factor (seconds of processing per second of audio)
# ESTIMATED_REALTIME_FACTOR=1.0

# Extra seconds added to time estimates for model load
MODEL_LOAD_BUFFER_SEC=10

# Hours to keep completed jobs in memory
JOB_TTL_HOURS=24

# JSONL log path for estimated vs actual transcription times
TIMING_LOG_PATH=data/timing_log.jsonl

# FastAPI app debug toggle
DEBUG=false
