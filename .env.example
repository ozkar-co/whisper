# Max upload size in MB
MAX_UPLOAD_MB=25

# Allowed audio file extensions (comma-separated)
ALLOWED_EXTENSIONS=webm,wav,m4a,mp3,ogg,flac

# Whisper model name: tiny, base, small, medium, large
WHISPER_MODEL=base

# Optional fixed language (e.g. en, es). Leave empty for auto-detection.
WHISPER_LANGUAGE=

# Timeout for transcription in seconds
WHISPER_TIMEOUT_SEC=120

# FastAPI app debug toggle
DEBUG=false
